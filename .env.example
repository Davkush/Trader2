# GEMINI_API_KEY: Required for Gemini AI API calls (chat, sentiment/risk agents,
# Pine Script conversion, autonomous bots engine).
GEMINI_API_KEY=""

# OPENROUTER_API_KEY: Required for OpenRouter AI API calls (Claude, Llama, etc. via the Terminal panel).
OPENROUTER_API_KEY=""

# VAULT_ENCRYPTION_KEY: 32-byte secret used for server-side AES-256-GCM encryption of vault entries.
# Required in production — the server refuses to start without it when NODE_ENV=production.
# Generate one with: openssl rand -base64 32
VAULT_ENCRYPTION_KEY="REPLACE_WITH_YOUR_OWN_32_BYTE_SECRET"

# API_BEARER_TOKEN: Static bearer token for the "system" account — grants backward-compatible,
# no-login access to /api/* routes. Required in production — the server refuses to start
# without it when NODE_ENV=production.
# Generate one with: openssl rand -hex 32
API_BEARER_TOKEN="REPLACE_WITH_YOUR_OWN_SECRET_TOKEN"

# JWT_SECRET: Signs and verifies per-user session tokens issued at /api/auth/login and
# /api/auth/register. NOT currently covered by the production fail-fast check — add it there
# (server.ts, alongside the API_BEARER_TOKEN / VAULT_ENCRYPTION_KEY check) before deploying,
# or anyone who reads this public repo can forge a login token for any user.
# Generate one with: openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_YOUR_OWN_SESSION_SECRET"

# NODE_ENV: set to "production" to enable the fail-fast startup check above and to serve the
# built dist/ output instead of the Vite dev server. Leave unset or "development" for local dev.
NODE_ENV="development"

# DB_DIR or PERSISTENT_DIR: Optional paths to customize where users and bots JSON database files 
# are stored (e.g., if you mount a persistent volume at /data). Defaults to process.cwd().
DB_DIR=""
PERSISTENT_DIR=""

# DATABASE_URL: SQLite database URL for Prisma
DATABASE_URL="file:./dev.db"

# POLYGON_API_KEY: Optional API key for Polygon.io high-fidelity stock market data.
POLYGON_API_KEY=""


